# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ── Servidor ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Cifrado AES-256-GCM (Ley 29733) ─────────────────────────
# Clave de 32 bytes (64 caracteres hex) para cifrar nombre y WhatsApp.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRÍTICO: si cambias esta clave, los registros anteriores no podrán descifrarse.
ENCRYPTION_KEY=reemplaza_con_64_chars_hex_generados_con_el_comando_de_arriba

# ── Base de datos SQLite ──────────────────────────────────────
# Ruta al archivo .db (se crea automáticamente si no existe).
# Default: <cwd>/data/glup.db
# DB_PATH=./data/glup.db

# ── Job de reintentos de webhook ─────────────────────────────
# Máximo de intentos por registro antes de dejarlo como FALLIDO permanente.
# Default: 5 (≈ 25 min de ventana de reintento con intervalo de 5 min)
RETRY_MAX_INTENTOS=5

# Intervalo entre ciclos del job en milisegundos.
# Default: 300000 (5 minutos). Mínimo recomendado: 60000 (1 min).
RETRY_INTERVAL_MS=300000

# ── n8n — Automatización WhatsApp ────────────────────────────
# URL del webhook en tu instancia n8n (obtén la URL del nodo Webhook de n8n).
# Si no está configurada, el backend omite el envío sin error.
N8N_WEBHOOK_URL=https://tu-instancia-n8n.com/webhook/glup-triaje

# Secreto compartido entre backend y n8n para verificar origen del request.
# Genéralo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
N8N_WEBHOOK_SECRET=cambia_esto_por_un_secreto_seguro_hex64
